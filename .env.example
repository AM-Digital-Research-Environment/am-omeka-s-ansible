# Semaphore UI configuration
# Copy to .env and update values before running docker-compose.semaphore.yml

# Admin account (created on first start)
SEMAPHORE_ADMIN=admin
SEMAPHORE_ADMIN_PASSWORD=changeme
SEMAPHORE_ADMIN_NAME=Admin
SEMAPHORE_ADMIN_EMAIL=admin@example.edu

# Database password
SEMAPHORE_DB_PASS=semaphore_secret

# Encryption key for stored credentials (generate with: head -c 32 /dev/urandom | base64)
SEMAPHORE_ACCESS_KEY_ENCRYPTION=
